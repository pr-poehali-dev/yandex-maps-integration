{
  "tests": [
    {
      "name": "List all photos",
      "method": "POST",
      "path": "/",
      "body": {"action": "list"},
      "expectedStatus": 200
    },
    {
      "name": "List service tabs",
      "method": "POST",
      "path": "/",
      "body": {"action": "list_tabs"},
      "expectedStatus": 200
    },
    {
      "name": "List service items for balloons",
      "method": "POST",
      "path": "/",
      "body": {"action": "list_items", "tab_key": "balloons"},
      "expectedStatus": 200
    },
    {
      "name": "Delete without token",
      "method": "POST",
      "path": "/",
      "body": {"action": "delete_photo", "id": 999},
      "expectedStatus": 401,
      "expectedBody": {"error": "Не авторизован"},
      "bodyMatcher": "partial"
    }
  ]
}